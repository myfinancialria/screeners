# Copy this file to .env and fill in your credentials.
# Get these from https://myapi.fyers.in/dashboard  (Create App)
#
# FYERS_APP_ID    -> your App ID / client_id, looks like  ABCD1234-100
# FYERS_SECRET_KEY-> the App Secret shown when you create the app
# FYERS_REDIRECT_URI -> must EXACTLY match what you registered in the app
#                       (for personal use, https://127.0.0.1 works fine)
#
# FYERS_ACCESS_TOKEN is filled in automatically by auth.py after you log in.

FYERS_APP_ID=your_app_id_here
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URI=https://127.0.0.1
FYERS_ACCESS_TOKEN=

# --- Email alerts (daily_scan.py) ---
# Gmail needs an APP PASSWORD (Google account -> Security -> 2-Step -> App passwords)
EMAIL_FROM=youraddress@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_TO=myfinancial.cfp@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# --- Headless TOTP login (fyers_login.py / GitHub Action) ---
FYERS_FY_ID=XN13999
FYERS_PIN=your_login_pin
FYERS_TOTP_SECRET=your_base32_totp_key
